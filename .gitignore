# ==========================================
# FraudShield Project - Git Ignore
# ==========================================

# --- 1. Data & Large Files (Never upload raw data) ---
*.csv
*.xlsx
*.parquet
data/
raw_data/

# --- 2. Trained Models & Heavy Binaries ---
# These are generated by your notebooks (Phase 1-5)
*.pkl
*.h5
*.pth
*.joblib
models/
checkpoints/

# --- 3. Results, Analysis & Logs ---
# Keep your repo clean of generated plots/metrics
results/
plots/
metrics/
*.log
*.png
*.pdf

# --- 4. Python & System Junk ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
bin/
lib/
develop-eggs/
dist/
eggs/
build/

# --- 5. Jupyter Notebooks Artifacts ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- 6. Streamlit & IDE Specific ---
.streamlit/config.toml
.vscode/
.idea/
.DS_Store
